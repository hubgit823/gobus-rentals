# --- Browser (Vite) ---
# Point the app at the Node mock API so Razorpay order/verify runs server-side (secret never in the bundle).
# Example when using `npm run dev:full` with mock API on 3020:
VITE_API_URL=http://localhost:3020

# Keep in-memory UI API for everything except payment routes (payment routes use VITE_API_URL above).
VITE_USE_LOCAL_API=true

# --- Mock API process only (never prefix with VITE_) ---
# Get Key ID + Key Secret from Razorpay Dashboard → Account & Settings → API Keys.
# Do NOT commit a real .env file. Rotate keys if they were ever pasted into chat or committed.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
